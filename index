import React, { useState, useEffect } from 'react';
import { 
  Home, ListTodo, CheckCircle2, Clock, Image as ImageIcon, 
  User, Calendar, Smartphone, Monitor, ShieldCheck, Send,
  CheckCircle, X, ChevronRight, Info, Activity, Zap, Layout, 
  Hourglass, Wrench, Loader2
} from 'lucide-react';

// --- ตั้งค่าระบบหลังบ้าน ---
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwljf5ejYlBLsaKcxPZxkOJJc72nSonh4grHaicpNIwDeYBjFeNlDYutYpV2TX-LX8WbA/exec'; 
const LIFF_ID = 'ใส่_LIFF_ID_ของคุณที่นี่';

const glassCardStyle = "bg-white/70 backdrop-blur-md border border-white/50 shadow-[0_8px_30px_rgb(255,182,193,0.3)] rounded-3xl";
const inputStyle = "w-full bg-white/50 border border-pink-100 focus:border-pink-300 focus:ring-2 focus:ring-pink-200 rounded-2xl px-4 py-3 text-gray-700 outline-none transition-all placeholder-pink-300 text-sm";
const labelStyle = "block text-xs font-semibold text-pink-400 mb-1.5 ml-1 uppercase tracking-wider";

export default function App() {
  const [activeTab, setActiveTab] = useState('home');
  const [isAdmin, setIsAdmin] = useState(false);
  const [selectedIssue, setSelectedIssue] = useState(null);
  
  // States สำหรับโหลดข้อมูลและโปรไฟล์ผู้ใช้
  const [isLoading, setIsLoading] = useState(true);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [issues, setIssues] = useState([]);
  const [userProfile, setUserProfile] = useState({ uid: '', displayName: 'Guest', pictureUrl: '' });

  // State ฟอร์ม (เพิ่ม Array สำหรับเก็บ Base64)
  const [formData, setFormData] = useState({
    submitterName: '', submitterEmail: '',
    app: '', days: '', accountEmail: '', accountPassword: '',
    screen: '', purchaseDate: '', problem: '',
    issueImages: [], 
    receiptImages: []
  });

  // 1. Initialize LIFF และดึงข้อมูลผู้ใช้ (ทำงานครั้งแรกเมื่อโหลดเว็บ)
  useEffect(() => {
    const initLiff = async () => {
      try {
        if (window.liff) {
          await window.liff.init({ liffId: LIFF_ID });
          if (window.liff.isLoggedIn()) {
            const profile = await window.liff.getProfile();
            setUserProfile({
              uid: profile.userId,
              displayName: profile.displayName,
              pictureUrl: profile.pictureUrl
            });
          }
        }
      } catch (err) {
        console.error('LIFF Init Error:', err);
      }
    };
    initLiff();
    fetchIssues(); // โหลดข้อมูลปัญหาจาก Sheet
  }, []);

  // 2. ฟังก์ชันดึงข้อมูลจาก Google Sheets (GET)
  const fetchIssues = async () => {
    setIsLoading(true);
    try {
      const response = await fetch(SCRIPT_URL);
      const data = await response.json();
      setIssues(data);
    } catch (error) {
      console.error("Fetch Data Error:", error);
    } finally {
      setIsLoading(false);
    }
  };

  // 3. ฟังก์ชันแปลงไฟล์รูปเป็น Base64
  const handleImageUpload = async (e, fieldName) => {
    const files = Array.from(e.target.files);
    if (files.length === 0) return;

    const base64Promises = files.map(file => {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = () => resolve(reader.result);
        reader.onerror = error => reject(error);
      });
    });

    try {
      const base64Results = await Promise.all(base64Promises);
      setFormData(prev => ({ 
        ...prev, 
        [fieldName]: [...prev[fieldName], ...base64Results] 
      }));
    } catch (error) {
      alert("เกิดข้อผิดพลาดในการอ่านไฟล์รูปภาพ");
    }
  };

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  // 4. ฟังก์ชันส่งข้อมูลเข้า Google Sheets (POST)
  const handleSubmit = async (e) => {
    e.preventDefault();
    setIsSubmitting(true);

    const payload = { ...formData, uid: userProfile.uid };

    try {
      const response = await fetch(SCRIPT_URL, {
        method: 'POST',
        body: JSON.stringify(payload),
      });
      const result = await response.json();

      if (result.status === 'success') {
        alert('ส่งข้อมูลแจ้งปัญหาเรียบร้อยแล้วค่ะ! 💖');
        // เคลียร์ฟอร์ม
        setFormData({
          submitterName: '', submitterEmail: '', app: '', days: '', accountEmail: '', 
          accountPassword: '', screen: '', purchaseDate: '', problem: '',
          issueImages: [], receiptImages: []
        });
        fetchIssues(); // รีเฟรชข้อมูลใหม่
        setActiveTab('list');
      } else {
        alert('เกิดข้อผิดพลาด: ' + result.message);
      }
    } catch (error) {
      alert('ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่');
    } finally {
      setIsSubmitting(false);
    }
  };

  const totalIssues = issues.length;
  const resolvedCount = issues.filter(i => i.status === 'completed').length;
  const unresolvedCount = totalIssues - resolvedCount;
  const resolvedPercentage = totalIssues > 0 ? (resolvedCount / totalIssues) * 100 : 0;

  const DonutChart = ({ percentage }) => {
    const radius = 35;
    const circumference = 2 * Math.PI * radius;
    const offset = circumference - (percentage / 100) * circumference;

    return (
      <div className="relative flex items-center justify-center w-20 h-20">
        <svg className="w-full h-full transform -rotate-90">
          <circle cx="40" cy="40" r={radius} stroke="currentColor" strokeWidth="6" fill="transparent" className="text-pink-100" />
          <circle cx="40" cy="40" r={radius} stroke="currentColor" strokeWidth="6" strokeDasharray={circumference} strokeDashoffset={offset} strokeLinecap="round" fill="transparent" className="text-pink-400 transition-all duration-1000 ease-out" />
        </svg>
        <div className="absolute flex flex-col items-center">
          <span className="text-sm font-black text-pink-500">{Math.round(percentage)}%</span>
        </div>
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-[#FFF5F8] text-gray-800 font-sans selection:bg-pink-200 flex justify-center overflow-hidden">
      <div className="w-full max-w-md bg-transparent h-screen flex flex-col relative pb-28 overflow-y-auto scroll-smooth custom-scrollbar">
        
        <div className="fixed top-[-10%] left-[-10%] w-64 h-64 bg-pink-200/40 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-blob pointer-events-none"></div>
        <div className="fixed top-[20%] right-[-10%] w-72 h-72 bg-purple-200/40 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-blob animation-delay-2000 pointer-events-none"></div>

        <div className="flex-1 p-5 z-10 space-y-6">
          
          {activeTab === 'home' && (
            <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
              {/* Header / Profile */}
              <div className={`${glassCardStyle} p-4 flex items-center justify-between`}>
                <div className="flex flex-col">
                  <div className="flex items-center gap-2">
                    <h1 className="text-2xl font-black text-pink-400 tracking-wider">TEST SYSTEM</h1>
                  </div>
                  <span className="text-xs text-pink-300 font-medium tracking-widest mt-1 uppercase">— ระบบแจ้งปัญหา —</span>
                </div>
                <div className="w-14 h-14 bg-white rounded-2xl border-2 border-pink-100 shadow-sm flex items-center justify-center overflow-hidden">
                  {userProfile.pictureUrl ? (
                    <img src={userProfile.pictureUrl} alt="Profile" className="w-full h-full object-cover" />
                  ) : (
                    <div className="w-full h-full bg-gradient-to-br from-pink-200 to-pink-100 flex items-center justify-center text-white">
                      <User size={28} />
                    </div>
                  )}
                </div>
              </div>

              {/* Banner Section */}
              <div className={`${glassCardStyle} p-0 h-32 relative overflow-hidden bg-gradient-to-br from-pink-300 to-pink-200 flex items-center justify-center`}>
                <div className="absolute top-[-20%] left-[-10%] w-32 h-32 bg-white/20 rounded-full blur-xl"></div>
                <div className="absolute bottom-[-20%] right-[-10%] w-40 h-40 bg-pink-400/20 rounded-full blur-2xl"></div>
                <div className="z-10 flex items-center gap-4 px-6 w-full h-full">
                  <div className="w-16 h-16 bg-white/30 backdrop-blur rounded-2xl flex items-center justify-center border border-white/40 shadow-sm">
                    <Layout className="text-white" size={32} />
                  </div>
                  <div>
                    <h2 className="text-white text-lg font-black tracking-widest drop-shadow-sm uppercase">Quick Support</h2>
                    <p className="text-white/80 text-[10px] font-bold uppercase tracking-widest mt-0.5">แจ้งปัญหาการใช้งานได้ตลอด 24 ชม.</p>
                  </div>
                </div>
              </div>

              {/* Dashboard */}
              <div className="grid grid-cols-2 gap-4">
                <div className={`${glassCardStyle} p-4 flex flex-col items-center justify-center text-center`}>
                  <h3 className="text-[10px] font-bold text-pink-400 mb-2 uppercase tracking-tighter">ภาพรวม</h3>
                  <DonutChart percentage={resolvedPercentage} />
                  <p className="text-[9px] text-pink-300 mt-2 font-medium">แก้ไขแล้ว / ทั้งหมด</p>
                </div>

                <div className={`${glassCardStyle} p-4 flex flex-col items-center justify-center text-center`}>
                  {unresolvedCount > 0 ? (
                    <>
                      <h3 className="text-[10px] font-bold text-pink-400 mb-2 uppercase tracking-tighter">รอตรวจสอบ</h3>
                      <div className="w-16 h-16 rounded-full border-4 border-pink-100 bg-white shadow-inner flex items-center justify-center">
                        <span className="text-2xl font-black text-pink-400">{unresolvedCount}</span>
                      </div>
                      <p className="text-[9px] text-pink-300 mt-2 font-medium">รายการ</p>
                    </>
                  ) : (
                    <div className="flex flex-col items-center justify-center py-2">
                      <div className="w-10 h-10 bg-green-100 text-green-500 rounded-full flex items-center justify-center mb-2 animate-pulse">
                        <CheckCircle size={20} />
                      </div>
                      <p className="text-[10px] font-bold text-green-500 leading-tight">เคลียร์ครบแล้ว! ✨</p>
                    </div>
                  )}
                </div>
              </div>

              {/* Submit Form */}
              <form onSubmit={handleSubmit} className="space-y-5 pb-10">
                <div className={`${glassCardStyle} p-5 space-y-4`}>
                  <div className="flex items-center gap-2 mb-1">
                    <div className="w-1 h-3 bg-pink-400 rounded-full"></div>
                    <h3 className="font-bold text-pink-500 text-xs uppercase tracking-widest">Contact Info</h3>
                  </div>
                  <div className="grid grid-cols-1 gap-4">
                    <div>
                      <label className={labelStyle}>ชื่อผู้แจ้ง</label>
                      <input required type="text" name="submitterName" value={formData.submitterName} onChange={handleInputChange} className={inputStyle} placeholder="ระบุชื่อของคุณ" />
                    </div>
                    <div>
                      <label className={labelStyle}>E-mail ผู้แจ้ง</label>
                      <input required type="email" name="submitterEmail" value={formData.submitterEmail} onChange={handleInputChange} className={inputStyle} placeholder="example@mail.com" />
                    </div>
                  </div>
                </div>

                <div className={`${glassCardStyle} p-5 space-y-4`}>
                   <div className="flex items-center gap-2 mb-1">
                    <div className="w-1 h-3 bg-pink-400 rounded-full"></div>
                    <h3 className="font-bold text-pink-500 text-xs uppercase tracking-widest">Issue Details</h3>
                  </div>

                  {/* อัพโหลดรูปปัญหาและประวัติซื้อแบบรองรับหลายรูป */}
                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <label className={labelStyle}>รูปปัญหา ({formData.issueImages.length})</label>
                      <label className={`flex flex-col items-center justify-center w-full h-20 border-2 border-dashed rounded-2xl cursor-pointer transition-colors ${formData.issueImages.length > 0 ? 'border-pink-300 bg-pink-50' : 'border-pink-100 bg-white/40 hover:bg-pink-50'}`}>
                        <ImageIcon className={formData.issueImages.length > 0 ? "text-pink-400 mb-1" : "text-pink-200 mb-1"} size={20} />
                        <span className="text-[9px] text-pink-300 font-bold uppercase">{formData.issueImages.length > 0 ? 'เพิ่มรูปอีก' : 'Upload'}</span>
                        <input type="file" multiple accept="image/*" onChange={(e) => handleImageUpload(e, 'issueImages')} className="hidden" />
                      </label>
                    </div>
                    <div>
                      <label className={labelStyle}>ประวัติซื้อ ({formData.receiptImages.length})</label>
                      <label className={`flex flex-col items-center justify-center w-full h-20 border-2 border-dashed rounded-2xl cursor-pointer transition-colors ${formData.receiptImages.length > 0 ? 'border-pink-300 bg-pink-50' : 'border-pink-100 bg-white/40 hover:bg-pink-50'}`}>
                        <ImageIcon className={formData.receiptImages.length > 0 ? "text-pink-400 mb-1" : "text-pink-200 mb-1"} size={20} />
                        <span className="text-[9px] text-pink-300 font-bold uppercase">{formData.receiptImages.length > 0 ? 'เพิ่มรูปอีก' : 'Upload'}</span>
                        <input type="file" multiple accept="image/*" onChange={(e) => handleImageUpload(e, 'receiptImages')} className="hidden" />
                      </label>
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <label className={labelStyle}>แอพ</label>
                      <div className="relative">
                        <Smartphone className="absolute left-3 top-3.5 text-pink-200" size={16} />
                        <input required type="text" name="app" value={formData.app} onChange={handleInputChange} className={`${inputStyle} pl-10`} placeholder="เช่น Netflix" />
                      </div>
                    </div>
                    <div>
                      <label className={labelStyle}>จำนวนวัน</label>
                      <input required type="number" name="days" value={formData.days} onChange={handleInputChange} className={inputStyle} placeholder="30" />
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <label className={labelStyle}>อีเมล (แอพ)</label>
                      <input required type="text" name="accountEmail" value={formData.accountEmail} onChange={handleInputChange} className={inputStyle} placeholder="Login Email" />
                    </div>
                    <div>
                      <label className={labelStyle}>พาสเวิร์ด</label>
                      <input required type="text" name="accountPassword" value={formData.accountPassword} onChange={handleInputChange} className={inputStyle} placeholder="Password" />
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <label className={labelStyle}>จอ</label>
                      <div className="relative">
                         <Monitor className="absolute left-3 top-3.5 text-pink-200" size={16} />
                        <input type="text" name="screen" value={formData.screen} onChange={handleInputChange} className={`${inputStyle} pl-9`} placeholder="จอ 1" />
                      </div>
                    </div>
                    <div>
                      <label className={labelStyle}>วันที่ซื้อ</label>
                      <div className="relative">
                         <Calendar className="absolute left-3 top-3.5 text-pink-200" size={14} />
                        <input required type="date" name="purchaseDate" value={formData.purchaseDate} onChange={handleInputChange} className={`${inputStyle} pl-9 text-[10px]`} />
                      </div>
                    </div>
                  </div>

                  <div>
                    <label className={labelStyle}>ปัญหา (แจ้งให้ชัดเจน)</label>
                    <textarea required name="problem" value={formData.problem} onChange={handleInputChange} className={`${inputStyle} min-h-[80px] py-3`} placeholder="แจ้งรายละเอียดปัญหาที่นี่..."></textarea>
                  </div>

                  <button 
                    type="submit" 
                    disabled={isSubmitting}
                    className="w-full bg-gradient-to-r from-pink-400 to-pink-300 text-white font-black py-4 rounded-2xl shadow-lg shadow-pink-200/50 flex items-center justify-center gap-2 transition-all active:scale-95 uppercase tracking-widest text-sm disabled:opacity-70 disabled:active:scale-100"
                  >
                    {isSubmitting ? <Loader2 size={18} className="animate-spin" /> : <Send size={18} />}
                    {isSubmitting ? 'กำลังส่งข้อมูล...' : 'Submit Report'}
                  </button>
                </div>
              </form>
            </div>
          )}

          {activeTab === 'list' && (
            <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500 pb-10">
              <div className="flex items-center justify-between px-2">
                <h2 className="text-xl font-black text-pink-500 flex items-center gap-2 uppercase tracking-tighter">
                    LIST <span className="text-pink-300 font-light tracking-widest">REPORT</span>
                </h2>
                <button 
                  onClick={fetchIssues}
                  className="px-3 py-1.5 rounded-xl text-[10px] font-bold flex items-center gap-1 transition-all bg-white text-gray-400 border border-gray-100 active:scale-95"
                >
                  <Activity size={12} /> รีเฟรช
                </button>
              </div>

              <div className="space-y-4">
                {isLoading ? (
                  <div className="flex flex-col items-center justify-center py-20 text-pink-300 gap-2">
                    <Loader2 size={32} className="animate-spin" />
                    <span className="text-xs font-bold uppercase tracking-widest">Loading Data...</span>
                  </div>
                ) : issues.length === 0 ? (
                  <div className="text-center py-20 text-pink-200 font-bold uppercase tracking-widest">No reports found</div>
                ) : (
                  issues.map((issue) => (
                    <div 
                      key={issue.id} 
                      onClick={() => setSelectedIssue(issue)}
                      className={`${glassCardStyle} p-4 flex flex-col gap-3 relative overflow-hidden active:scale-[0.98] transition-all cursor-pointer group`}
                    >
                      <div className="absolute right-[15%] top-[45%] -translate-y-1/2 opacity-[0.08] text-pink-300 -rotate-12 scale-[4.5] pointer-events-none transition-transform group-hover:scale-[5] duration-500">
                        {issue.status === 'completed' ? <CheckCircle2 /> : 
                         issue.status === 'in_progress' ? <Wrench /> : <Hourglass />}
                      </div>

                      <div className={`absolute left-0 top-0 bottom-0 w-1 ${
                        issue.status === 'completed' ? 'bg-green-400' : 
                        issue.status === 'in_progress' ? 'bg-orange-400' : 'bg-pink-400'
                      }`}></div>

                      <div className="flex justify-between items-start z-10">
                        <div>
                          <div className="flex items-center gap-2 mb-1">
                            <span className="font-black text-gray-700 text-sm uppercase">{issue.app || 'N/A'}</span>
                            <span className="text-[9px] font-bold text-gray-300">{issue.date}</span>
                          </div>
                          <p className="text-[10px] font-bold text-pink-400 mb-2">BY: {issue.submitterName}</p>
                          <p className="text-xs text-gray-500 leading-relaxed font-medium line-clamp-2 italic">"{issue.problem}"</p>
                        </div>
                        
                        <div className="flex flex-col items-end gap-2">
                          <div className={`px-2 py-1 rounded-lg text-[9px] font-black uppercase flex items-center gap-1 border backdrop-blur-sm ${
                            issue.status === 'completed' ? 'bg-green-50/80 text-green-600 border-green-100' : 
                            issue.status === 'in_progress' ? 'bg-orange-50/80 text-orange-600 border-orange-100' : 
                            'bg-pink-50/80 text-pink-600 border-pink-100'
                          }`}>
                            {issue.status === 'completed' ? 'Fixed' : 
                             issue.status === 'in_progress' ? 'Doing' : 'Pending'}
                          </div>
                          <ChevronRight className="text-pink-200 group-hover:text-pink-400 transition-colors" size={16} />
                        </div>
                      </div>
                    </div>
                  ))
                )}
              </div>
            </div>
          )}
        </div>

        {selectedIssue && (
          <div className="fixed inset-0 z-[100] flex items-end justify-center px-4 pb-8 animate-in fade-in duration-300">
            <div className="absolute inset-0 bg-pink-900/10 backdrop-blur-sm" onClick={() => setSelectedIssue(null)}></div>
            <div className={`${glassCardStyle} w-full max-w-md max-h-[90vh] overflow-hidden flex flex-col relative animate-in slide-in-from-bottom-8 duration-500 shadow-2xl border-2 border-white/80`}>
              <div className="p-5 border-b border-pink-50 flex justify-between items-center bg-white/40">
                <div className="flex items-center gap-3">
                  <div className={`w-10 h-10 rounded-2xl flex items-center justify-center ${selectedIssue.status === 'completed' ? 'bg-green-100 text-green-500' : 'bg-pink-100 text-pink-500'}`}>
                    <Info size={20} />
                  </div>
                  <div>
                    <h3 className="text-sm font-black text-gray-700 uppercase leading-none">Issue Details</h3>
                    <p className="text-[10px] text-pink-400 font-bold mt-1 uppercase tracking-tighter">ID: {selectedIssue.id}</p>
                  </div>
                </div>
                <button onClick={() => setSelectedIssue(null)} className="w-8 h-8 rounded-full bg-white shadow-sm flex items-center justify-center text-gray-400 hover:text-pink-500 transition-colors">
                  <X size={18} />
                </button>
              </div>

              <div className="flex-1 overflow-y-auto p-6 space-y-6 custom-scrollbar">
                <div className="flex justify-between items-center bg-pink-50/50 p-3 rounded-2xl border border-pink-100">
                   <div className="flex items-center gap-2">
                    <Smartphone size={16} className="text-pink-400" />
                    <span className="text-sm font-black text-gray-700 uppercase">{selectedIssue.app}</span>
                   </div>
                   <div className={`px-3 py-1 rounded-full text-[10px] font-black uppercase ${
                      selectedIssue.status === 'completed' ? 'bg-green-400 text-white' : 
                      selectedIssue.status === 'in_progress' ? 'bg-orange-400 text-white' : 'bg-pink-400 text-white'
                   }`}>
                      {selectedIssue.status === 'completed' ? 'Fixed' : 
                       selectedIssue.status === 'in_progress' ? 'In Progress' : 'Pending'}
                   </div>
                </div>

                <div className="grid grid-cols-2 gap-4">
                  <div className="space-y-3">
                    <h4 className={labelStyle}>Contact Info</h4>
                    <div className="text-xs space-y-1">
                      <p className="font-bold text-gray-700">{selectedIssue.submitterName}</p>
                      <p className="text-gray-400 truncate">{selectedIssue.submitterEmail}</p>
                    </div>
                  </div>
                  <div className="space-y-3">
                    <h4 className={labelStyle}>Account Info</h4>
                    <div className="text-xs space-y-1">
                      <p className="font-bold text-gray-700 truncate">{selectedIssue.accountEmail}</p>
                      <p className="text-gray-400">Pass: {selectedIssue.accountPassword}</p>
                    </div>
                  </div>
                </div>

                <div className="grid grid-cols-3 gap-2 bg-white/50 p-3 rounded-2xl border border-pink-50">
                   <div className="text-center">
                     <p className="text-[9px] text-pink-300 font-bold uppercase">Days</p>
                     <p className="text-xs font-black text-gray-600">{selectedIssue.days} วัน</p>
                   </div>
                   <div className="text-center border-x border-pink-50">
                     <p className="text-[9px] text-pink-300 font-bold uppercase">Screen</p>
                     <p className="text-xs font-black text-gray-600">{selectedIssue.screen}</p>
                   </div>
                   <div className="text-center">
                     <p className="text-[9px] text-pink-300 font-bold uppercase">Purchased</p>
                     <p className="text-xs font-black text-gray-600">{selectedIssue.purchaseDate?.substring(0,10)}</p>
                   </div>
                </div>

                <div className="space-y-2">
                  <h4 className={labelStyle}>Problem Description</h4>
                  <div className="bg-white/80 p-4 rounded-2xl border border-pink-50 shadow-inner">
                    <p className="text-sm text-gray-600 leading-relaxed font-medium italic">
                      "{selectedIssue.problem}"
                    </p>
                  </div>
                </div>
              </div>

              <div className="p-6 border-t border-pink-50 bg-white/60">
                 <button onClick={() => setSelectedIssue(null)} className="w-full py-4 bg-pink-400 text-white font-black rounded-2xl shadow-lg shadow-pink-200 flex items-center justify-center gap-2 uppercase tracking-widest text-xs">
                   Close Details
                 </button>
              </div>
            </div>
          </div>
        )}

        <div className="fixed bottom-6 left-1/2 -translate-x-1/2 w-auto min-w-[180px] bg-white/60 backdrop-blur-xl border border-white/40 shadow-[0_10px_30px_rgba(255,192,203,0.3)] rounded-full px-2 py-1.5 flex gap-1 items-center justify-center z-50">
          <button onClick={() => setActiveTab('home')} className={`flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300 ${activeTab === 'home' ? 'bg-pink-400 text-white shadow-md scale-105' : 'text-pink-300 hover:bg-pink-50'}`}>
            <Home size={18} strokeWidth={activeTab === 'home' ? 3 : 2} />
            {activeTab === 'home' && <span className="text-[10px] font-black uppercase tracking-widest">Report</span>}
          </button>
          <div className="w-[1px] h-4 bg-pink-100 mx-1"></div>
          <button onClick={() => setActiveTab('list')} className={`flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300 ${activeTab === 'list' ? 'bg-pink-400 text-white shadow-md scale-105' : 'text-pink-300 hover:bg-pink-50'}`}>
             <div className="relative">
              <ListTodo size={18} strokeWidth={activeTab === 'list' ? 3 : 2} />
              {unresolvedCount > 0 && activeTab !== 'list' && (
                <span className="absolute -top-1 -right-1 w-2 h-2 bg-orange-400 rounded-full border border-white"></span>
              )}
            </div>
            {activeTab === 'list' && <span className="text-[10px] font-black uppercase tracking-widest">History</span>}
          </button>
        </div>
      </div>
      
      <style dangerouslySetInnerHTML={{__html: `
        @keyframes blob {
          0% { transform: translate(0px, 0px) scale(1); }
          33% { transform: translate(20px, -40px) scale(1.05); }
          66% { transform: translate(-15px, 15px) scale(0.95); }
          100% { transform: translate(0px, 0px) scale(1); }
        }
        .animate-blob { animation: blob 8s infinite alternate ease-in-out; }
        .animation-delay-2000 { animation-delay: 2s; }
        ::-webkit-scrollbar { width: 0px; background: transparent; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #fce7f3; border-radius: 10px; }
      `}} />
    </div>
  );
}